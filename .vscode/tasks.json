{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start React",
            "type": "npm",
            "script": "start",
            "path": "src/main/frontend",
            "isBackground": true,
            "problemMatcher": {
                "owner": "webpack",
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Starting the development server",
                    "endsPattern": "Compiled successfully|Compiled with warnings|Failed to compile"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}